programa {
  funcao inicio() {
    real val[3]
      
    escreva("Digite o valor do índice 0: ")
    leia(val[0])
    escreva("Digite o valor do índice 1: ")
    leia(val[1])
    val[2]= val[0]+val[1]

    escreva("Vetor completo \n")
    escreva("Índice 0: ",val[0],"\n")
    escreva("Índice 1: ",val[1],"\n")
    escreva("Índice 2: ",val[2])

  }
}
