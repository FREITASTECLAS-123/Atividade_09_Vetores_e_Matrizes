programa {
  funcao inicio() {
    cadeia cor[3]

    escreva("Digite a primeira cor: ")
    leia(cor[0])
    escreva("Digite a segunda cor: ")
    leia(cor[1])
    escreva("Digite a terceira cor: ")
    leia(cor[2])

    escreva("Ordem Inversa \n")
    escreva(cor[2],"\n")
    escreva(cor[1],"\n")
    escreva(cor[0])
  }
}
