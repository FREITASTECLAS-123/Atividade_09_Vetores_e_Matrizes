    programa {
      funcao inicio() {
    cadeia nome[3]
    escreva("Digite o nome da sua comida favorita: ")
    leia(nome[0])
    escreva("Digite o nome da sua segunda comida favorita: ")
    leia(nome[1])
    escreva("Digite o nome da sua terceira comida favorita: ")
    leia(nome[2])
    escreva(nome[1])
    }
    }
